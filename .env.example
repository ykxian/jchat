# App
APP_NAME=jchat
APP_ENV=dev

# Backend
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=dev

# Database
DB_NAME=jchat
DB_USER=jchat
DB_PASSWORD=jchat
DB_PORT=5432
DB_URL=jdbc:postgresql://localhost:5432/jchat

# Redis
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# Security
JWT_SECRET=change-me-to-a-random-base64-secret
APP_CRYPTO_KEY=change-me-to-a-random-base64-key

# Storage
STORAGE_ROOT=./data/files

# LLM
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_API_KEY=

# Tools
APP_TOOLS_HTTP_FETCH_ALLOWLIST=
APP_TOOLS_SERPAPI_KEY=

